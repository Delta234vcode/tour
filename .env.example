# Frontend dev (Vite proxies to backend; keys used only in proxy headers — never in the browser bundle)
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
GROK_API_KEY=

# Python API (scrapling/server.py) — never expose in the client
GEMINI_API_KEY=

# Optional: comma-separated origins for AI proxy routes (e.g. http://localhost:3000,https://yourapp.com)
ALLOWED_ORIGINS=

# Optional: shared secret; clients must send header X-AI-Proxy-Secret
AI_PROXY_SECRET=
